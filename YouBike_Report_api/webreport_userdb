app.put('/role_citys/:roleid', async (req, res) => {
  const id = req.params.roleid;
  const payload = req.body;

  if (!payload || payload.length === 0) {
    return res.status(200).json({ message: "無資料需更新" });
  }

  try {
    // 1. 刪除舊資料 (使用參數化查詢防止 SQL 注入)
    const deleteQuery = `DELETE FROM YouBikeDB.user_citys WHERE users_id = @userId`;
    await bigquery.query({
      query: deleteQuery,
      params: { userId: id }
    });

    // 2. 構建批量插入 SQL (一條指令插入所有資料)
    // 格式: INSERT INTO table (cols) VALUES (v1, v2), (v3, v4)...
    const valuesStrings = payload.map((_, i) => `(@uId${i}, @cId${i})`).join(', ');
    const insertQuery = `INSERT INTO YouBikeDB.user_citys (users_id, city_id) VALUES ${valuesStrings}`;

    // 構建參數物件
    const params = {};
    payload.forEach((item, i) => {
      params[`uId${i}`] = item.users_id;
      params[`cId${i}`] = item.city_id;
    });

    await bigquery.query({
      query: insertQuery,
      params: params
    });

    res.status(200).json({ message: "修改成功" });
  } catch (error) {
    console.error("更新失敗:", error);
    res.status(500).json({ message: "更新失敗", error: error.message });
  }
});